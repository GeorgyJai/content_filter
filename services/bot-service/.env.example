# Telegram Bot Configuration
BOT_TOKEN=your_telegram_bot_token_here

# Telegram API Configuration (for folder parsing with Telethon)
# Get these from https://my.telegram.org/apps
TELEGRAM_API_ID=0
TELEGRAM_API_HASH=

# User Service gRPC Configuration
USER_SERVICE_HOST=user-service
USER_SERVICE_PORT=50051

# Digest Service gRPC Configuration (для будущего использования)
DIGEST_SERVICE_HOST=digest-service
DIGEST_SERVICE_PORT=50052

# Bot Settings
LOG_LEVEL=INFO
