# YouTube API Configuration
YOUTUBE_API_KEY=your_youtube_api_key_here
YOUTUBE_API_VERSION=v3

# Channels to Monitor (comma-separated channel IDs)
# Example: YOUTUBE_CHANNELS=UCxxxxxx,UCyyyyyy,UCzzzzzz
YOUTUBE_CHANNELS=

# Polling Configuration
POLL_INTERVAL_SECONDS=300
MAX_RESULTS_PER_CHANNEL=10

# Transcription Configuration
ENABLE_TRANSCRIPTION=false
WHISPER_MODEL=base
TRANSCRIPTION_LANGUAGE=ru

# Download Configuration
TEMP_DOWNLOAD_DIR=/tmp/youtube_downloads
MAX_VIDEO_DURATION_MINUTES=60

# RabbitMQ Configuration
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_EXCHANGE=content_exchange
RABBITMQ_ROUTING_KEY=raw.youtube

# PostgreSQL Configuration
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=content_filter_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Logging
LOG_LEVEL=INFO
