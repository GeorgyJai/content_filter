# Telegram API Credentials
# Получите на https://my.telegram.org/apps
TELEGRAM_API_ID=your_api_id
TELEGRAM_API_HASH=your_api_hash
TELEGRAM_PHONE=+1234567890
TELEGRAM_SESSION_NAME=collector_session

# RabbitMQ Configuration
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=admin_password
RABBITMQ_EXCHANGE=content_exchange
RABBITMQ_ROUTING_KEY=raw.telegram

# PostgreSQL Configuration
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=content_filter_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here

# Service Settings
LOG_LEVEL=INFO
POLL_INTERVAL=60
MAX_MESSAGES_PER_CHANNEL=50
