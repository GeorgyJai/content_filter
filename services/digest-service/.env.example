# Database Configuration
DB_HOST=postgres
DB_PORT=5432
DB_NAME=content_filter_db
DB_USER=postgres
DB_PASSWORD=postgres_password

# gRPC Configuration
GRPC_PORT=50052
GRPC_MAX_WORKERS=10

# Service Connections
USER_SERVICE_HOST=user-service
USER_SERVICE_PORT=50051
RANKING_SERVICE_HOST=ranking-service
RANKING_SERVICE_PORT=50053
BOT_SERVICE_HOST=bot-service
BOT_SERVICE_PORT=50054

# Scheduler Configuration
SCHEDULER_ENABLED=true
SCHEDULER_CHECK_INTERVAL=60

# Digest Settings
DEFAULT_DIGEST_INTERVAL_HOURS=8
DEFAULT_MAX_ITEMS=10
MIN_CONTENT_AGE_MINUTES=5

# Logging
LOG_LEVEL=INFO
