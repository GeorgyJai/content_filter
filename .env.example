# ============================================
# Database Configuration
# ============================================
POSTGRES_DB=content_filter_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ============================================
# RabbitMQ Configuration
# ============================================
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=your_secure_password_here
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672

# ============================================
# Telegram Bot Configuration
# ============================================
# Bot Service - получите токен у @BotFather в Telegram
BOT_TOKEN=your_bot_token_here

# Telegram Collector Service (для будущего использования)
TELEGRAM_API_ID=your_api_id
TELEGRAM_API_HASH=your_api_hash

# ============================================
# VK API Configuration (Collector Service)
# ============================================
VK_API_VERSION=5.131
VK_CONFIRMATION_TOKEN=your_vk_confirmation_token_here
VK_SECRET_KEY=your_vk_secret_key_here
VK_ACCESS_TOKEN=your_vk_access_token_here

# ============================================
# YouTube API Configuration (Collector Service)
# ============================================
YOUTUBE_API_KEY=your_youtube_api_key_here
YOUTUBE_API_VERSION=v3
# Comma-separated list of YouTube channel IDs to monitor
# Example: YOUTUBE_CHANNELS=UCxxxxxx,UCyyyyyy,UCzzzzzz
YOUTUBE_CHANNELS=
YOUTUBE_POLL_INTERVAL_SECONDS=300
YOUTUBE_MAX_RESULTS_PER_CHANNEL=10
# Transcription settings (requires significant resources)
YOUTUBE_ENABLE_TRANSCRIPTION=false
YOUTUBE_WHISPER_MODEL=base
YOUTUBE_TRANSCRIPTION_LANGUAGE=ru
YOUTUBE_MAX_VIDEO_DURATION_MINUTES=60

# ============================================
# Service Ports (gRPC)
# ============================================
USER_SERVICE_PORT=50051
DIGEST_SERVICE_PORT=50052
RANKING_SERVICE_PORT=50053
SUMMARIZATION_SERVICE_PORT=50054
FEEDBACK_SERVICE_PORT=50055

# ============================================
# Logging Configuration
# ============================================
LOG_LEVEL=INFO
LOG_FORMAT=json

# ============================================
# Application Settings
# ============================================
ENVIRONMENT=development
DEBUG=false
